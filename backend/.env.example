# ===========================================
# MegaSharkAI - Переменные окружения
# ===========================================
# Скопируйте этот файл как .env и заполните значениями
# ===========================================

# ====================
# Приложение
# ====================
DEBUG=true
ENVIRONMENT=development

# ====================
# База данных PostgreSQL
# ====================
POSTGRES_USER=megashark
POSTGRES_PASSWORD=<dev-or-production-postgres-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=megashark_db

# ====================
# Redis (для Celery)
# ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=megashark_redis_dev

# ====================
# AI сервисы
# ====================
# Яндекс GPT (получить в Яндекс Облаке)
YANDEX_GPT_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# DeepSeek (опционально)
DEEPSEEK_API_KEY=

# OpenAI (опционально)
OPENAI_API_KEY=

# ====================
# Парсинг
# ====================
PLAYWRIGHT_BROWSER=chromium
PARSING_TIMEOUT=30000
PROXY_LIST=

# ====================
# Безопасность
# ====================
# Сгенерировать случайную строку для продакшена
SECRET_KEY=<generate-secure-random-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Лимит auth-запросов (login/register/reset) с одного IP в минуту
AUTH_RATE_LIMIT_PER_MINUTE=10

# Сгенерировать Fernet-ключ:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate-stable-fernet-key>

# ====================
# Email (опционально)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
USE_TLS=true
APP_URL=http://localhost:3000

# ====================
# Telegram (уведомления)
# ====================
# Токен бота от @BotFather. Нужен для отправки Telegram-уведомлений.
TELEGRAM_BOT_TOKEN=

# ====================
# Репрайсинг
# ====================
# Глобальный рубильник реального применения цен на маркетплейсах.
# false — расчёт работает, но отправка цены на площадку блокируется.
REPRICING_APPLY_ENABLED=true

# ====================
# CORS
# ====================
# Для production укажите конкретные домены, wildcard запрещён.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
